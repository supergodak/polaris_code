{
  "name": "polaris",
  "version": "0.1.0",
  "type": "module",
  "description": "Fully AI-driven coding agent powered by local LLMs",
  "repository": {
    "type": "git",
    "url": "https://github.com/supergodak/polaris_code.git"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "coding-agent",
    "llm",
    "local-llm",
    "cli",
    "terminal"
