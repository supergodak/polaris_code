    "typescript": "^5",
    "vitest": "^3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "marked": "^17.0.4",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
